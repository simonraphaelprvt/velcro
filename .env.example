# =============================================================================
# VELCRO — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth — Simple password protection
# Set a strong password. Stored as a hashed cookie on login.
# -----------------------------------------------------------------------------
VELCRO_PASSWORD=your-secret-password-here

# Used to sign the auth cookie. Generate with: openssl rand -base64 32
AUTH_SECRET=your-32-char-random-secret-here

# Domain allowed to embed VELCRO in an iframe (your Dashboard URL)
# Example: https://simonmoser.dev  or  https://your-dashboard.vercel.app
VELCRO_EMBED_ORIGIN=https://your-dashboard-url-here

# -----------------------------------------------------------------------------
# Anthropic (Claude)
# https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Model to use. Default: claude-sonnet-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# OpenAI (Whisper + Embeddings)
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Embedding model for vault search. Do not change unless you re-index everything.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# ElevenLabs (Text-to-Speech)
# https://elevenlabs.io/app/voice-lab
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id-here

# -----------------------------------------------------------------------------
# Supabase (Vector Store)
# https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Google OAuth (Calendar + Gmail)
# https://console.cloud.google.com/apis/credentials
# Scopes needed: calendar.readonly, gmail.readonly
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Stored after first OAuth flow — set manually or via /api/auth/google
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Local Writer Webhook (Phase 7 — optional)
# URL of the local_writer.py server running on Simon's Mac
# Use Cloudflare Tunnel or ngrok to expose it
# -----------------------------------------------------------------------------
LOCAL_WRITER_URL=https://your-tunnel.trycloudflare.com
LOCAL_WRITER_SECRET=your-shared-secret-for-the-webhook

# -----------------------------------------------------------------------------
# Feature Flags (NEXT_PUBLIC_* so client can read them)
# Defaults: Phase 1 ON, later phases OFF until their backends are wired up.
# Set any to "false" to disable.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FEATURE_WAKE_WORD=true

NEXT_PUBLIC_FEATURE_CALL_PREP=false
NEXT_PUBLIC_FEATURE_DEBRIEF=false
NEXT_PUBLIC_FEATURE_MORNING_BRIEF=false

NEXT_PUBLIC_FEATURE_SPOTIFY=false
NEXT_PUBLIC_FEATURE_WEB_SEARCH=false
NEXT_PUBLIC_FEATURE_WEATHER=false

NEXT_PUBLIC_FEATURE_SPATIAL_MAP=false
NEXT_PUBLIC_FEATURE_DECISION_MATRIX=false
NEXT_PUBLIC_FEATURE_CONVERSATION_REPLAY=false
NEXT_PUBLIC_FEATURE_SCENARIO=false
NEXT_PUBLIC_FEATURE_RELATIONSHIP_WEB=false
NEXT_PUBLIC_FEATURE_MOOD_BOARD=false
NEXT_PUBLIC_FEATURE_MIRROR=false
